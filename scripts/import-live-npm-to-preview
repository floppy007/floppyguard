#!/bin/bash -e

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="${DIR}/.."

cd "${ROOT_DIR}/backend"

TARGET_SQLITE_FILE="${TARGET_SQLITE_FILE:-${ROOT_DIR}/.local-data/backend/database.sqlite}"
SOURCE_DB_HOST="${SOURCE_DB_HOST:-127.0.0.1}"
SOURCE_DB_PORT="${SOURCE_DB_PORT:-3306}"
SOURCE_DB_USER="${SOURCE_DB_USER:-npm}"
SOURCE_DB_PASSWORD="${SOURCE_DB_PASSWORD:-npm}"
SOURCE_DB_NAME="${SOURCE_DB_NAME:-npm}"
PREVIEW_EMAIL="${PREVIEW_EMAIL:-preview@example.com}"
PREVIEW_PASSWORD="${PREVIEW_PASSWORD:-Preview123!}"

env \
	TARGET_SQLITE_FILE="${TARGET_SQLITE_FILE}" \
	SOURCE_DB_HOST="${SOURCE_DB_HOST}" \
	SOURCE_DB_PORT="${SOURCE_DB_PORT}" \
	SOURCE_DB_USER="${SOURCE_DB_USER}" \
	SOURCE_DB_PASSWORD="${SOURCE_DB_PASSWORD}" \
	SOURCE_DB_NAME="${SOURCE_DB_NAME}" \
	PREVIEW_EMAIL="${PREVIEW_EMAIL}" \
	PREVIEW_PASSWORD="${PREVIEW_PASSWORD}" \
	node ./scripts/import-live-npm.js
