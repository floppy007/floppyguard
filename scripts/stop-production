#!/bin/bash -e

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${DIR}/.." && pwd)"
DATA_DIR="${ROOT_DIR}/.local-data"
BACKEND_PID_FILE="${DATA_DIR}/backend-production.pid"
FRONTEND_PID_FILE="${DATA_DIR}/frontend-production.pid"
BACKEND_PORT="${BACKEND_PORT:-3300}"
FRONTEND_PORT="${FRONTEND_PORT:-4173}"

port_listener_pid() {
	local port=$1
	ss -ltnp 2>/dev/null | awk -v port=":${port}" '
		$4 ~ port {
			if (match($0, /pid=[0-9]+/)) {
				print substr($0, RSTART + 4, RLENGTH - 4)
				exit
			}
		}
	'
}

stop_pid_file() {
	local pid_file=$1
	local label=$2
	if [ -f "${pid_file}" ]; then
		pid="$(cat "${pid_file}")"
		if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
			kill "${pid}" || true
			echo "Stopped ${label} PID ${pid}"
		fi
		rm -f "${pid_file}"
	fi
}

stop_pid_file "${FRONTEND_PID_FILE}" "frontend"
stop_pid_file "${BACKEND_PID_FILE}" "backend"

sleep 1

frontend_listener="$(port_listener_pid "${FRONTEND_PORT}")"
backend_listener="$(port_listener_pid "${BACKEND_PORT}")"

if [ -n "${FRONTEND_PORT}" ]; then
	if [ -n "${frontend_listener}" ]; then
		echo "Frontend port ${FRONTEND_PORT} still in use by PID ${frontend_listener}"
	else
		echo "Frontend port ${FRONTEND_PORT} is free"
	fi
fi

if [ -n "${BACKEND_PORT}" ]; then
	if [ -n "${backend_listener}" ]; then
		echo "Backend port ${BACKEND_PORT} still in use by PID ${backend_listener}"
	else
		echo "Backend port ${BACKEND_PORT} is free"
	fi
fi
