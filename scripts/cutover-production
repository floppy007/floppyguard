#!/bin/bash -e
# cutover-production
# Replaces the legacy NPM Docker container + wg-gui with FloppyGuard (host-based).
#
# What this does:
#   1. Creates /data symlink → /opt/npm/data  (FloppyGuard writes nginx configs there)
#   2. Creates required nginx cache and log directories
#   3. Disables the nginx default site (would conflict on port 80)
#   4. Verifies the FloppyGuard nginx config compiles cleanly
#   5. Stops the NPM Docker container  ← point of no return
#   6. Reloads system nginx to activate FloppyGuard config on 80/81/443
#   7. Enables + starts floppyguard-backend systemd service
#   8. Health checks

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${DIR}/.." && pwd)"
BACKEND_PORT="${BACKEND_PORT:-3300}"

# ---------------------------------------------------------------------------
step() { echo; echo "==> $*"; }
die()  { echo "ERROR: $*" >&2; exit 1; }
# ---------------------------------------------------------------------------

step "Checking prerequisites"

[ -d "${ROOT_DIR}/frontend/dist" ] || die "frontend/dist missing — run: cd frontend && yarn build"
[ -d "${ROOT_DIR}/backend/node_modules" ] || die "backend/node_modules missing — run: cd backend && yarn install"
command -v systemctl >/dev/null || die "systemd not found"
command -v docker    >/dev/null || die "docker not found"
systemctl is-active nginx.service >/dev/null || die "nginx.service is not running"

step "Creating required /data subdirectories"

# /data is FloppyGuard's own data dir (separate from /opt/npm/data).
# FloppyGuard regenerates nginx configs from MySQL on startup.
mkdir -p /data/nginx/proxy_host /data/nginx/redirection_host /data/nginx/dead_host \
         /data/nginx/stream /data/nginx/default_host /data/nginx/temp \
         /data/letsencrypt-acme-challenge /data/logs /data/access /data/custom_ssl
echo "Directories ready"

step "Creating nginx cache directories"

mkdir -p /var/lib/nginx/cache/public /var/lib/nginx/cache/private
echo "Cache directories ready"

step "Disabling nginx default site (conflicts on port 80)"

if [ -L /etc/nginx/sites-enabled/default ]; then
    rm /etc/nginx/sites-enabled/default
    echo "Removed /etc/nginx/sites-enabled/default"
else
    echo "Default site already disabled"
fi

step "Testing FloppyGuard nginx configuration"

# Test includes the floppyguard.conf and all /data/nginx/**/*.conf files.
# The NPM Docker nginx is still running on 80/81/443 at this point,
# so nginx -t succeeds without binding to those ports.
nginx -t || die "nginx -t failed — fix config before proceeding"

step "Stopping NPM Docker container  [POINT OF NO RETURN]"

if docker ps -q --filter name=npm-app-1 | grep -q .; then
    docker stop npm-app-1
    echo "npm-app-1 stopped"
else
    echo "npm-app-1 was not running"
fi

step "Reloading system nginx (activate FloppyGuard config on 80/81/443)"

# npm-app-1's nginx (pid 933) is gone now, ports 80/81/443 are free.
nginx -s reload
echo "nginx reloaded"

# Brief wait for worker processes to spin up
sleep 2

step "Enabling and starting floppyguard-backend"

systemctl daemon-reload
systemctl enable floppyguard-backend.service
systemctl start  floppyguard-backend.service

step "Waiting for backend to become ready"

for i in $(seq 1 60); do
    if curl -fsS "http://127.0.0.1:${BACKEND_PORT}/" >/dev/null 2>&1; then
        echo "Backend ready on port ${BACKEND_PORT}"
        break
    fi
    if [ "${i}" -eq 60 ]; then
        echo "Backend did not become ready in 60s" >&2
        echo "Check logs: journalctl -u floppyguard-backend -n 50" >&2
        exit 1
    fi
    sleep 1
done

step "Health checks"

check_url() {
    local url=$1
    local label=$2
    if curl -fsS -o /dev/null -w "%{http_code}" "${url}" 2>/dev/null | grep -qE "^[23]"; then
        echo "  OK  ${label}  ${url}"
    else
        echo "  FAIL  ${label}  ${url}" >&2
        HEALTH_FAIL=1
    fi
}

HEALTH_FAIL=0
check_url "http://127.0.0.1:81/"                    "Admin UI (port 81)"
check_url "http://127.0.0.1:${BACKEND_PORT}/api/"   "Backend API"

if [ "${HEALTH_FAIL}" -eq 1 ]; then
    echo
    echo "One or more health checks failed. Backend logs:" >&2
    journalctl -u floppyguard-backend -n 30 --no-pager >&2
    exit 1
fi

step "Done"
echo
echo "FloppyGuard is live."
echo "  Admin UI : http://$(hostname -I | awk '{print $1}'):81"
echo "  API      : http://127.0.0.1:${BACKEND_PORT}"
echo "  Logs     : journalctl -u floppyguard-backend -f"
echo
echo "To disable wg-gui (port 8080) once WireGuard management is fully migrated:"
echo "  rm /etc/nginx/sites-enabled/wg-gui && nginx -s reload"
